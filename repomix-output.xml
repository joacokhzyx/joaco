                                    data-media
                                    src={p.media}
                                    alt={p.alt}
                                    loading="lazy"
                                    className={`absolute inset-0 h-full w-full object-cover ${i === 0 ? "opacity-100" : "opacity-0"}`}
                                />
                            ))}
                        </div>
                    </div>
